{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user (Student, Teacher, Admin)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["STUDENT", "TEACHER", "ADMIN"] },
        "active": { "type": "boolean" },
        "matricula": { "type": "string" },
        "groupIds": { "type": "array" },
        "subjectIds": { "type": "array" },
        "averageGrade": { "type": "number" },
        "wildcards": { "type": "object" },
        "treasureMissions": {
          "type": "object",
          "properties": {
            "dailyCount": { "type": "number" },
            "lastResetDay": { "type": "string" }
          }
        },
        "studentCode": { "type": "string" },
        "lastSeenAt": { "type": "number" }
      },
      "required": ["userId", "role"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "Evaluation mission created by a teacher",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "teacherId": { "type": "string" },
        "type": { "type": "string" },
        "groupId": { "type": "string" },
        "status": { "type": "string" },
        "isOpen": { "type": "boolean" },
        "questionsCount": { "type": "number" },
        "customLogoUrl": { "type": "string" },
        "customPhrase": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["EASY", "MEDIUM", "HARD"] },
        "assignedUserIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Question": {
      "title": "Question",
      "description": "Single question within a quiz",
      "type": "object",
      "properties": {
        "quizId": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string" },
        "options": { "type": "array" },
        "correctAnswer": { "type": "string" },
        "points": { "type": "number" }
      }
    },
    "Session": {
      "title": "Session",
      "description": "Live game session",
      "type": "object",
      "properties": {
        "quizId": { "type": "string" },
        "teacherId": { "type": "string" },
        "status": { "type": "string" },
        "joinCode": { "type": "string" },
        "type": { "type": "string", "enum": ["CLASICO", "POR_EQUIPOS", "A_LA_CIMA", "LA_TORRE"] },
        "teams": { "type": "array" },
        "currentQuestionIndex": { "type": "number" },
        "currentTurnTeam": { "type": "number" },
        "currentTurnPlayerId": { "type": "string" },
        "currentTurnPlayerName": { "type": "string" },
        "questionStartTime": { "type": "number" },
        "lastResponseCorrect": { "type": "boolean" },
        "config": { "type": "object" }
      }
    },
    "Survey": {
      "title": "Survey",
      "description": "Questionnaire for students",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "active": { "type": "boolean" },
        "teacherId": { "type": "string" }
      }
    },
    "AIGenerationHistory": {
      "title": "AI Generation History",
      "description": "History of questions generated by AI for a teacher",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "topic": { "type": "string" },
        "count": { "type": "number" },
        "type": { "type": "string" },
        "difficulty": { "type": "string" },
        "results": { "type": "array" },
        "timestamp": { "type": "number" }
      }
    },
    "QuestionBank": {
      "title": "Question Bank",
      "description": "A collection of questions for a specific topic or subject",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "teacherId": { "type": "string" },
        "subjectId": { "type": "string" },
        "topic": { "type": "string" },
        "questionsCount": { "type": "number" },
        "createdAt": { "type": "number" }
      }
    },
    "LibraryQuestion": {
      "title": "Library Question",
      "description": "A reusable question stored in a bank",
      "type": "object",
      "properties": {
        "bankId": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string" },
        "options": { "type": "array" },
        "correctAnswer": { "type": "string" },
        "explanation": { "type": "string" },
        "incorrectExplanations": { "type": "object" },
        "difficulty": { "type": "string", "enum": ["EASY", "MEDIUM", "HARD"] },
        "subjectId": { "type": "string" },
        "topic": { "type": "string" },
        "subtopic": { "type": "string" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "Global user profiles" },
    "quizzes": { "schema": "Quiz", "description": "Assessment missions" },
    "quizzes/{quizId}/questions": { "schema": "Question", "description": "Questions per quiz" },
    "sessions": { "schema": "Session", "description": "Live game instances" },
    "surveys": { "schema": "Survey", "description": "Student surveys" },
    "surveyResponses": { "schema": "object", "description": "Survey replies" },
    "config": { "schema": "object", "description": "Global configurations" },
    "requests": { "schema": "object", "description": "Access requests" },
    "ai_generation_history": { "schema": "AIGenerationHistory", "description": "AI generation history per teacher" },
    "question_banks": { "schema": "QuestionBank", "description": "User question banks" },
    "library_questions": { "schema": "LibraryQuestion", "description": "Centralized reusable questions" }
  }
}
