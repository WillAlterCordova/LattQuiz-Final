rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -- 1. THE MASTER GATE & HELPERS --
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      // Mandate verification except for super admin or dummy domains used for internal login
      return request.auth.token.email_verified == true || 
             request.auth.token.email == 'cordova.wil@gmail.com' ||
             request.auth.token.email.matches('.*@lattquiz\\..*');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getUserData() {
      // In Rules, get() is cached per request. We avoid redundant exists() calls.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'cordova.wil@gmail.com' ||
        getUserData().role == 'ADMIN'
      );
    }

    function isTeacher() {
      return isSignedIn() && (
        request.auth.token.email == 'cordova.wil@gmail.com' ||
        getUserData().role in ['ADMIN', 'TEACHER']
      );
    }

    function isOwner(userId) {
      return isSignedIn() && (
        request.auth.uid == userId ||
        request.auth.token.email.matches('^' + userId.lower() + '@lattquiz\\..*$')
      );
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // -- 2. VALIDATION BLUEPRINTS --

    function isValidUser(data) {
      let requiredFields = ['role', 'userId', 'displayName', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.role in ['STUDENT', 'TEACHER', 'ADMIN', 'PENDING'] &&
             data.userId == request.auth.uid &&
             data.userId is string && data.userId.size() <= 128 &&
             (!('email' in data) || (data.email is string && data.email.size() <= 256)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 256)) &&
             (!('matricula' in data) || (data.matricula is string && data.matricula.size() <= 32));
    }

    function isValidQuiz(data) {
      let requiredFields = ['title', 'teacherId', 'questionsCount', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.title is string && data.title.size() <= 256 &&
             data.teacherId == request.auth.uid &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2048));
    }

    function isValidSession(data) {
      let requiredFields = ['quizId', 'teacherId', 'status', 'type', 'joinCode', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.quizId is string && data.quizId.size() <= 128 &&
             data.teacherId is string && data.teacherId.size() <= 128 &&
             data.status in ['LOBBY', 'IN_PROGRESS', 'COMPLETED', 'FINISHED'] &&
             data.type in ['CLASICO', 'POR_EQUIPOS', 'A_LA_CIMA', 'LA_TORRE', 'MEMORAMA', 'IDENTIFICADOR'] &&
             data.joinCode is string && data.joinCode.size() == 6;
    }

    // -- 0. GLOBAL SAFETY NET --
    match /{document=**} {
      allow read, write: if false;
    }

    // -- COLLECTIONS --

    match /users/{userId} {
      // Direct access only by auth or specific roles
      allow get: if isSignedIn() && (isOwner(userId) || isTeacher());
      // Only admins or teachers can list users (with narrow search)
      allow list: if isTeacher();
      
      allow create: if isSignedIn() && isEmailVerified() && (
        (isOwner(userId) && isValidUser(incoming())) ||
        isAdmin()
      );
      
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(userId) && (!('role' in incoming()) || incoming().role == existing().role) && (!('userId' in incoming()) || incoming().userId == existing().userId)) ||
        (isTeacher() && existing().role == 'PENDING')
      );
      
      allow delete: if isAdmin();
    }

    match /config/{configId} {
      allow read: if true; // Allow public read for maintenance mode checks
      allow write: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if true;
      allow create, update, delete: if isTeacher();
    }

    match /groups/{groupId} {
      allow read: if true;
      allow create, update, delete: if isTeacher();
    }

    match /requests/{requestId} {
      allow create: if true; // Public request
      allow list, get, update, delete: if isTeacher();
    }

    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow create: if isTeacher() && isEmailVerified() && isValidQuiz(incoming());
      allow update: if (isAdmin() || (isTeacher() && existing().teacherId == request.auth.uid)) && isValidQuiz(incoming());
      allow delete: if isAdmin() || (isTeacher() && existing().teacherId == request.auth.uid);
      
      match /questions/{questionId} {
        allow read: if isSignedIn();
        allow write: if isTeacher() && isEmailVerified();
      }
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isTeacher() && isEmailVerified() && 
                      incoming().teacherId == request.auth.uid &&
                      isValidSession(incoming());
      allow update: if (isAdmin() || (isTeacher() && existing().teacherId == request.auth.uid) || 
                       (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['participants', 'status', 'currentQuestionIndex', 'teams', 'currentTurnTeam', 'currentTurnPlayerId', 'currentTurnPlayerName', 'suggestions', 'lastResponseCorrect']))) && 
                       isValidSession(incoming());
      allow delete: if isAdmin() || (isTeacher() && existing().teacherId == request.auth.uid);

      match /participants/{participantId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isEmailVerified() && 
                        (participantId == request.auth.uid || isAdmin() || (isTeacher() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.teacherId == request.auth.uid));
      }
    }

    match /attempts/{attemptId} {
      allow get: if isAdmin() || isTeacher() || (isSignedIn() && existing().studentId == request.auth.uid);
      allow list: if isAdmin() || isTeacher() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && isEmailVerified() && incoming().studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /surveys/{surveyId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacher() && isEmailVerified();
    }

    match /surveyResponses/{respId} {
      allow get: if isAdmin() || isTeacher() || (isSignedIn() && existing().studentId == request.auth.uid);
      allow list: if isAdmin() || isTeacher() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && isEmailVerified() && incoming().studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /ai_generation_history/{historyId} {
      allow read: if isAdmin() || (isTeacher() && existing().teacherId == request.auth.uid);
      allow create: if isTeacher() && incoming().teacherId == request.auth.uid;
      allow delete: if isTeacher() && existing().teacherId == request.auth.uid;
    }

    match /question_banks/{bankId} {
      allow read: if isAdmin() || (isTeacher() && (existing().teacherId == request.auth.uid || existing().isPublic == true));
      allow create: if isTeacher() && incoming().teacherId == request.auth.uid;
      allow update, delete: if isTeacher() && existing().teacherId == request.auth.uid;
    }

    match /library_questions/{questionId} {
      allow read: if isAdmin() || (isTeacher() && (existing().teacherId == request.auth.uid || existing().isPublic == true));
      allow create: if isTeacher() && incoming().teacherId == request.auth.uid;
      allow update, delete: if isTeacher() && existing().teacherId == request.auth.uid;
    }

    match /system_errors/{errorId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /system_alerts/{alertId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['readBy']));
    }

    match /violations/{violationId} {
      allow read: if isAdmin() || isTeacher();
      allow create: if isSignedIn() && isEmailVerified();
      allow update, delete: if isAdmin();
    }
  }
}
